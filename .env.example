# Aciosa environment configuration
# Copy to .env and fill in real values. .env is gitignored and must never be committed.

# --- Database ---
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=aciosa
DB_USER=aciosa
# Use a strong, unique password. Do NOT reuse the example value below.
DB_PASSWORD=change-me-db-password
DB_ROOT_PASSWORD=change-me-root-password

# --- App / admin auth ---
# Initial password applied to seeded administrators that have no password yet.
# If left unset, a random one-time password is generated and printed to the logs
# on first boot. Always change admin passwords after first login.
DEFAULT_ADMIN_PASSWORD=

# Secret used to sign admin session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Keep this stable across restarts so sessions survive; keep it secret.
SESSION_SECRET=

# Admin session lifetime in hours (default 12).
SESSION_TTL_HOURS=12

# Set to "true" when serving over HTTPS so the session cookie gets the Secure flag.
COOKIE_SECURE=false

# Seed administrators as "Name,Phone" pairs separated by semicolons. Real names
# and phone numbers belong here (in .env), never in source control. Example:
#   SEED_ADMINISTRATORS="Administrador Demo,8888 0000;Jane Doe,8888 1111"
SEED_ADMINISTRATORS=

# --- OpenWA / WhatsApp ---
OPENWA_ENABLED=true
OPENWA_API_URL=http://openwa:8080
# Use a strong, unique key shared with the openwa service.
OPENWA_API_KEY=change-me-openwa-key
